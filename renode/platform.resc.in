$bin ?= @${CMAKE_BINARY_DIR}/${RENODE_BINARY_FILE}

using sysbus

mach create
machine LoadPlatformDescription @${CMAKE_BINARY_DIR}/nrf52840.repl
emulation CreateServerSocketTerminal 4321 "netcat_term"
connector Connect sysbus.uart0 netcat_term
sysbus LoadELF $bin
showAnalyzer uart0

machine StartGdbServer 3333